ENVIRONMENT=development
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=rag_db
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_password
POSTGRES_DSN=postgresql://rag_user:rag_password@postgres:5432/rag_db
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=rag-documents
CHROMA_HOST=chromadb
CHROMA_PORT=8000
# Si rag-api tourne dans Docker sur Windows/macOS et Ollama est local,
# utilisez host.docker.internal pour atteindre le service hôte.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama2-mini
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=500
CHUNK_OVERLAP=50
AIRFLOW_EXECUTOR=LocalExecutor
AIRFLOW_DB_URI=sqlite:///airflow.db
