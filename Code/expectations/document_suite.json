{
  "expectation_suite_name": "document_suite",
  "expectations": [
    {
      "expectation_type": "expect_table_to_exist"
    },
    {
      "expectation_type": "expect_table_column_count_to_equal",
      "kwargs": {
        "value": 8
      }
    },
    {
      "expectation_type": "expect_table_columns_to_match_set",
      "kwargs": {
        "value": [
          "id",
          "run_id",
          "object_name",
          "chunk_index",
          "char_start",
          "chunk_text",
          "chroma_id",
          "created_at"
        ]
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "chunk_text"
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "object_name"
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "chroma_id"
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {
        "column": "run_id"
      }
    },
    {
      "expectation_type": "expect_column_value_lengths_to_be_between",
      "kwargs": {
        "column": "chunk_text",
        "min_value": 10,
        "max_value": 2000
      }
    },
    {
      "expectation_type": "expect_column_values_to_match_regex",
      "kwargs": {
        "column": "object_name",
        "regex": "^(raw|processed)/"
      }
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "chunk_index",
        "min_value": 0,
        "max_value": 500
      }
    }
  ]
}
